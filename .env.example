# Required
SECRET_KEY=your-secret-key-here
DB_PATH=data/forecast.db

# Optional — event discovery
OPENAI_API_KEY=sk-...

# Optional — Google Calendar sync (legacy single-user push)
ENABLE_GOOGLE_CALENDAR_SYNC=

# Optional — Google OAuth Calendar push (for Android users)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — admin (receives Google OAuth failure alerts)
ADMIN_EMAIL=

# Optional — Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# Optional — scheduler tuning (defaults shown)
TIER1_TIMES=05:30,11:00,15:30,18:30,22:00
TIER2_TIMES=06:00,17:00
TIER3_TIME=02:00
